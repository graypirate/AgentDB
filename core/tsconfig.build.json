{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "noEmitOnError": true,
    "rootDir": ".",
    "outDir": "./dist",
    "declaration": true,
    "rewriteRelativeImportExtensions": true
  },
  "include": [
    "index.ts",
    "API/**/*.ts",
    "CLI/**/*.ts",
    "src/**/*.ts"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "test"
  ]
}
